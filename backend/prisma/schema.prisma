generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PerfilUsuario {
  ALUNO
  PROFESSOR

  @@map("perfil_usuario")
}

enum StatusPublicacao {
  PENDENTE
  APROVADA
  REPROVADA

  @@map("status_publicacao")
}

enum TipoReacao {
  CURTIDA

  @@map("tipo_reacao")
}

enum DificuldadeMissao {
  FACIL
  MEDIA
  DIFICIL

  @@map("dificuldade_missao")
}

enum StatusRespostaMissao {
  ENVIADA
  AVALIADA

  @@map("status_resposta_missao")
}

enum TipoNotificacao {
  CURTIDA
  COMENTARIO
  MISSAO
  PUBLICACAO_APROVADA
  PUBLICACAO_REPROVADA
  AVALIACAO

  @@map("tipo_notificacao")
}

model Usuario {
  id              String        @id @default(uuid()) @db.Uuid
  nomeCompleto    String        @map("nome_completo")
  email           String        @unique
  senha           String
  fotoPerfil      String?       @map("foto_perfil")
  perfil          PerfilUsuario
  escola          String
  turma           String?
  disciplinaId    String?       @map("disciplina_id") @db.Uuid
  pontuacao       Int           @default(0)
  nivel           Int           @default(1)
  dataCriacao     DateTime      @default(now()) @map("data_criacao")
  dataAtualizacao DateTime      @updatedAt @map("data_atualizacao")

  disciplina      Disciplina?      @relation(fields: [disciplinaId], references: [id])
  publicacoes     Publicacao[]
  comentarios     Comentario[]
  reacoes         Reacao[]
  missoes         Missao[]
  respostasMissao RespostaMissao[]
  notificacoes    Notificacao[]

  @@index([escola])
  @@index([turma])
  @@index([disciplinaId])
  @@map("usuarios")
}

model Disciplina {
  id              String   @id @default(uuid()) @db.Uuid
  nome            String   @unique
  descricao       String?
  dataCriacao     DateTime @default(now()) @map("data_criacao")
  dataAtualizacao DateTime @updatedAt @map("data_atualizacao")

  professores Usuario[]
  publicacoes Publicacao[]
  missoes     Missao[]

  @@map("disciplinas")
}

model Publicacao {
  id                    String           @id @default(uuid()) @db.Uuid
  titulo                String
  descricao             String
  imagemUrl             String?          @map("imagem_url")
  status                StatusPublicacao @default(PENDENTE)
  quantidadeComentarios Int              @default(0) @map("quantidade_comentarios")
  quantidadeCurtidas    Int              @default(0) @map("quantidade_curtidas")
  usuarioId             String           @map("usuario_id") @db.Uuid
  disciplinaId          String           @map("disciplina_id") @db.Uuid
  dataCriacao           DateTime         @default(now()) @map("data_criacao")
  dataAtualizacao       DateTime         @updatedAt @map("data_atualizacao")

  usuario     Usuario      @relation(fields: [usuarioId], references: [id])
  disciplina  Disciplina   @relation(fields: [disciplinaId], references: [id])
  comentarios Comentario[]
  reacoes     Reacao[]

  @@index([usuarioId])
  @@index([disciplinaId])
  @@index([status])
  @@index([dataCriacao])
  @@map("publicacoes")
}

model Comentario {
  id              String   @id @default(uuid()) @db.Uuid
  conteudo        String
  usuarioId       String   @map("usuario_id") @db.Uuid
  publicacaoId    String   @map("publicacao_id") @db.Uuid
  dataCriacao     DateTime @default(now()) @map("data_criacao")
  dataAtualizacao DateTime @updatedAt @map("data_atualizacao")

  usuario    Usuario    @relation(fields: [usuarioId], references: [id])
  publicacao Publicacao @relation(fields: [publicacaoId], references: [id])

  @@index([usuarioId])
  @@index([publicacaoId])
  @@index([dataCriacao])
  @@map("comentarios")
}

model Reacao {
  id           String     @id @default(uuid()) @db.Uuid
  usuarioId    String     @map("usuario_id") @db.Uuid
  publicacaoId String     @map("publicacao_id") @db.Uuid
  tipo         TipoReacao @default(CURTIDA)
  dataCriacao  DateTime   @default(now()) @map("data_criacao")

  usuario    Usuario    @relation(fields: [usuarioId], references: [id])
  publicacao Publicacao @relation(fields: [publicacaoId], references: [id])

  @@unique([usuarioId, publicacaoId])
  @@index([usuarioId])
  @@index([publicacaoId])
  @@map("reacoes")
}

model Missao {
  id                 String            @id @default(uuid()) @db.Uuid
  titulo             String
  descricao          String
  criteriosAvaliacao String?           @map("criterios_avaliacao")
  prazo              DateTime
  pontuacao          Int
  dificuldade        DificuldadeMissao
  professorId        String            @map("professor_id") @db.Uuid
  disciplinaId       String            @map("disciplina_id") @db.Uuid
  dataCriacao        DateTime          @default(now()) @map("data_criacao")
  dataAtualizacao    DateTime          @updatedAt @map("data_atualizacao")

  professor       Usuario          @relation(fields: [professorId], references: [id])
  disciplina      Disciplina       @relation(fields: [disciplinaId], references: [id])
  respostasMissao RespostaMissao[]

  @@index([professorId])
  @@index([disciplinaId])
  @@index([prazo])
  @@map("missoes")
}

model RespostaMissao {
  id                String               @id @default(uuid()) @db.Uuid
  resposta          String
  imagemUrl         String?              @map("imagem_url")
  status            StatusRespostaMissao @default(ENVIADA)
  nota              Float?
  feedbackProfessor String?              @map("feedback_professor")
  dataEnvio         DateTime             @default(now()) @map("data_envio")
  dataAtualizacao   DateTime             @updatedAt @map("data_atualizacao")
  alunoId           String               @map("aluno_id") @db.Uuid
  missaoId          String               @map("missao_id") @db.Uuid

  aluno  Usuario @relation(fields: [alunoId], references: [id])
  missao Missao  @relation(fields: [missaoId], references: [id])

  @@unique([alunoId, missaoId])
  @@index([alunoId])
  @@index([missaoId])
  @@index([status])
  @@map("respostas_missao")
}

model Notificacao {
  id          String          @id @default(uuid()) @db.Uuid
  usuarioId   String          @map("usuario_id") @db.Uuid
  titulo      String
  mensagem    String
  tipo        TipoNotificacao
  lida        Boolean         @default(false)
  dataCriacao DateTime        @default(now()) @map("data_criacao")

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
  @@index([dataCriacao])
  @@map("notificacoes")
}
