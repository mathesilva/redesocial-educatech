generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PerfilUsuario {
  ALUNO
  PROFESSOR

  @@map("perfil_usuario")
}

model Usuario {
  id              String        @id @default(uuid()) @db.Uuid
  nomeCompleto    String        @map("nome_completo")
  email           String        @unique
  senha           String
  fotoPerfil      String?       @map("foto_perfil")
  perfil          PerfilUsuario
  escola          String
  turma           String?
  disciplinaId    String?       @map("disciplina_id") @db.Uuid
  pontuacao       Int           @default(0)
  nivel           Int           @default(1)
  dataCriacao     DateTime      @default(now()) @map("data_criacao")
  dataAtualizacao DateTime      @updatedAt @map("data_atualizacao")

  disciplina Disciplina? @relation(fields: [disciplinaId], references: [id])

  @@index([escola])
  @@index([turma])
  @@index([disciplinaId])
  @@map("usuarios")
}

model Disciplina {
  id              String   @id @default(uuid()) @db.Uuid
  nome            String
  descricao       String?
  dataCriacao     DateTime @default(now()) @map("data_criacao")
  dataAtualizacao DateTime @updatedAt @map("data_atualizacao")

  professores Usuario[]

  @@index([nome])
  @@map("disciplinas")
}
